# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# -----------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------

# Generate with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=True

# Comma-separated — add your Render hostname in production
ALLOWED_HOSTS=localhost,127.0.0.1

# Full origins for CSRF — required in production
CSRF_TRUSTED_ORIGINS=https://myapp.onrender.com

# -----------------------------------------------------------------------
# Database
# Leave DB_ENGINE unset (or sqlite3) for local development — uses SQLite.
# On Render: set all DB_* variables from the PostgreSQL service dashboard.
# -----------------------------------------------------------------------
DB_ENGINE=django.db.backends.postgresql
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=your_db_host
DB_PORT=5432

# -----------------------------------------------------------------------
# Media files
# On Render: mount a persistent disk at /var/data/media and set this var.
# Locally: leave unset — defaults to <BASE_DIR>/media
# -----------------------------------------------------------------------
MEDIA_ROOT=/var/data/media
